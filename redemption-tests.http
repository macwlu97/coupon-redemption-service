### 1. CREATE COUPON (Base Setup)
# Creates a coupon with a limit of 2 uses for Poland (PL).
# Testing uniqueness and initial state.
POST http://localhost:8082/api/v1/coupons
Content-Type: application/json

{
  "code": "SUMMER2026",
  "usageLimit": 2,
  "targetCountry": "PL"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 201 || response.status === 409, "Status should be 201 (Created) or 409 (Already Exists)");
    });
%}

---

### 2. VALID REDEMPTION (User 1 - Success)
# Testing successful redemption from a Polish IP.
# We use X-Forwarded-For to simulate a real Polish public IP.
POST http://localhost:8081/api/v1/usages/SUMMER2026/redeem
X-Forwarded-For: 89.64.12.150
User-Id: candidate_001
Content-Type: application/json

{}

> {%
    client.test("First redemption successful", function() {
        client.assert(response.status === 200 || response.status === 201, "Should be 200/201 OK");
    });
%}

---

### 3. RE-USE PROTECTION (User 1 - Fail)
# Testing business rule: "One user can use a coupon only once".
# Expecting 409 Conflict or 422 Business Rule Violation.
POST http://localhost:8081/api/v1/usages/SUMMER2026/redeem
X-Forwarded-For: 89.64.12.150
User-Id: candidate_001
Content-Type: application/json

{}

> {%
    client.test("User cannot reuse the same coupon", function() {
        client.assert(response.status === 409 || response.status === 422, "Should block second attempt by same user");
    });
%}

---

### 4. INVALID COUNTRY PROTECTION (User 2 - Fail)
# Testing business rule: "Country defined in coupon limits usage to persons from that country".
# Using a German IP (starting with 5.147.x.x) for a Polish coupon.
POST http://localhost:8081/api/v1/usages/SUMMER2026/redeem
X-Forwarded-For: 5.147.160.1
User-Id: candidate_002
Content-Type: application/json

{}

> {%
    client.test("Should reject request from foreign IP", function() {
        client.assert(response.status === 422, "Should return 422 due to country mismatch");
    });
%}

---

### 5. LIMIT PROTECTION (User 2 - Success, then User 3 - Fail)
# First, fill the remaining slot (2nd usage).
POST http://localhost:8081/api/v1/usages/SUMMER2026/redeem
X-Forwarded-For: 89.64.12.150
User-Id: candidate_002
Content-Type: application/json

{}

### Then, attempt 3rd usage (Should fail - Limit reached).
POST http://localhost:8081/api/v1/usages/SUMMER2026/redeem
X-Forwarded-For: 89.64.12.150
User-Id: candidate_003
Content-Type: application/json

{}

> {%
    client.test("Should reject when limit is reached", function() {
        client.assert(response.status === 409 || response.status === 422, "Should return Error when limit exceeded");
    });
%}

---

### 6. HISTORY CHECK
# Verify that the history for candidate_001 contains the redemption record.
GET http://localhost:8081/api/v1/usages/history/candidate_001
Accept: application/json

> {%
    client.test("History contains data", function() {
        client.assert(response.body.length > 0, "Redemption list should not be empty");
    });
%}