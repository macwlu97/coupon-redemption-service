### 1. Setup: Create a New Coupon
# Scenario: Create a coupon with a limit of 2 specifically for Poland (PL)
POST http://localhost:8080/api/v1/coupons
Content-Type: application/json

{
  "code": "SPRING2026",
  "usageLimit": 2,
  "targetCountry": "PL"
}

> {%
    client.test("Coupon created or already exists", function() {
        client.assert(response.status === 201 || response.status === 200, "Response status is not 201/200");
    });
%}

### 2. Geofencing Test: Reject US IP
# Scenario: Attempt redemption from a US IP (8.8.8.8) - Should be rejected (422)
POST http://localhost:8080/api/v1/usages/SPRING2026/redeem
Content-Type: application/json
X-Forwarded-For: 8.8.8.8
User-Id: stranger_danger

{}

> {%
    client.test("Forbidden country rejected", function() {
        client.assert(response.status === 422, "Response status is not 422");
    });
%}

### 3. Redemption #1: Success (User Alpha)
# Scenario: Valid redemption from a Polish IP
POST http://localhost:8080/api/v1/usages/SPRING2026/redeem
Content-Type: application/json
X-Forwarded-For: 89.64.12.150
User-Id: user_alpha

{}

> {%
    client.test("First redemption successful", function() {
        client.assert(response.status === 200 || response.status === 201, "Response status is not 200/201");
    });
%}

### 4. Double Redemption Check: Same User
# Scenario: User Alpha tries to use the same coupon again - Should be rejected (409)
POST http://localhost:8080/api/v1/usages/SPRING2026/redeem
Content-Type: application/json
X-Forwarded-For: 89.64.12.150
User-Id: user_alpha

{}

> {%
    client.test("Double redemption blocked", function() {
        client.assert(response.status === 409, "Response status is not 409 Conflict");
    });
%}

### 5. Redemption #2: Success (User Beta)
# Scenario: Second valid slot used by a different user
POST http://localhost:8080/api/v1/usages/SPRING2026/redeem
Content-Type: application/json
X-Forwarded-For: 89.64.12.150
User-Id: user_beta

{}

### 6. Usage Limit Test: Reject User Gamma
# Scenario: Third user tries to redeem but limit (2) is reached - Should be rejected (400/422)
POST http://localhost:8080/api/v1/usages/SPRING2026/redeem
Content-Type: application/json
X-Forwarded-For: 89.64.12.150
User-Id: user_gamma

{}

> {%
    client.test("Global limit enforced", function() {
        client.assert(response.status === 400 || response.status === 422, "Response status should be 400/422");
    });
%}